void InitMsg(MsgQue *msgq)
{
    uint8_t i;

    if(msgq==0)
        return;
    msgq->r=0;
    msgq->w=0;
    for(i=0; i<MSG_LEN; i++)
    {
        msgq->msg[i].msgtype=0;
        msgq->msg[i].msgval1=0;
        msgq->msg[i].msgval2=0;
    }
}


void SendMsg(MsgQue *msgq,uint8_t type,uint32_t val1,uint32_t val2)
{
    if(msgq==0)
        return;
    msgq->msg[msgq->w].msgtype=type;
    msgq->msg[msgq->w].msgval1=val1;
    msgq->msg[msgq->w].msgval2=val2;
    msgq->w=(msgq->w+1)%MSG_LEN;
}

TMSG* RevMsg(MsgQue *msgq)
{
    TMSG *p=0;

    if(msgq==0)
        return 0;

    if(msgq->r!=msgq->w)
    {
        p=&msgq->msg[msgq->r];
        msgq->r=(msgq->r+1)%MSG_LEN;
        return p;
    }

    return 0;
}


void A_Fxn(void)
{
    static uint8_t  psta[5]= {0};
    uint8_t i;
    float val=0;

    if(strokeA.tim_trg > 0)
        return;

    psta[0]=psta[1];
    psta[1]=psta[2];
    psta[2]=psta[3];
    psta[3]=psta[4];
    psta[4]=GPIO_ReadInputDataBit(GPIOD,GPIO_Pin_5);//每200ms读pin状态,超过1000ms都是高电平，表示一次冲击停止

    for(i=0; i<5; i++)
    {
        if(0==(psta[i]&0x20))
        {
            i=0xff;
            break;
        }
    }
    if (i != 0xff)
    {
        memset(psta,0,5);
        //strokeA.tim_len=(strokeA.tim_e>=strokeA.tim_s)?(strokeA.tim_e-strokeA.tim_s + compen):0;
        val= (strokeA.tim_e>=strokeA.tim_s)?(strokeA.tim_e-strokeA.tim_s + compen):0;
        strokeA.tim_len=(uint32_t)((val/5) + 0.5);
        strokeA.tim_trg=1;
        single_trg+=1;
        strokeA.tim_len=(strokeA.tim_len & 0x00ffffff)|(0x01000000);//A相+时长
        SendMsg(&MsgSystem,MSG_COUNT,strokeA.tim_len,strokeA.tim_s);//发送相别+时长+起始时间(用于判断是否是相邻两项同时被雷击)

		compen=-2;
    }

}


void B_Fxn(void)
{
    static uint8_t  pstb[5]= {0};
    uint8_t i;

    if(strokeB.tim_trg > 0)
        return;

    pstb[0]=pstb[1];
    pstb[1]=pstb[2];
    pstb[2]=pstb[3];
    pstb[3]=pstb[4];
    pstb[4]=GPIO_ReadInputDataBit(GPIOD,GPIO_Pin_6);//每200ms读pin状态,超过1000ms都是高电平，表示一次冲击停止

    for(i=0; i<5; i++)
    {
        if(0==(pstb[i]&0x40))
        {
            i=0xff;
            break;
        }
    }
    if (i != 0xff)
    {
        memset(pstb,0,5);
        //strokeB.tim_len=(strokeB.tim_e>=strokeB.tim_s)?(strokeB.tim_e-strokeB.tim_s):(0xffffffff+strokeB.tim_e-strokeB.tim_s);
        strokeB.tim_len=(strokeB.tim_e>=strokeB.tim_s)?(strokeB.tim_e-strokeB.tim_s + compen):0;
        strokeB.tim_trg=1;
        single_trg+=1;
        strokeB.tim_len=(strokeB.tim_len & 0x00ffffff)|(0x02000000);
        SendMsg(&MsgSystem,MSG_COUNT,strokeB.tim_len,strokeB.tim_s);

        compen=-2;
    }

}


void C_Fxn(void)
{
    static uint8_t  pstc[5]= {0};
    uint8_t i;

    if(strokeC.tim_trg > 0)
        return;

    pstc[0]=pstc[1];
    pstc[1]=pstc[2];
    pstc[2]=pstc[3];
    pstc[3]=pstc[4];
    pstc[4]=GPIO_ReadInputDataBit(GPIOD,GPIO_Pin_7);//每200ms读pin状态,超过1000ms都是高电平，表示一次冲击停止

    for(i=0; i<5; i++)
    {
        if(0==(pstc[i]&0x80))
        {
            i=0xff;
            break;
        }
    }

    if (i != 0xff)
    {
        memset(pstc,0,5);
        //strokeC.tim_len=(strokeC.tim_e>=strokeC.tim_s)?(strokeC.tim_e-strokeC.tim_s):(0xffffffff+strokeC.tim_e-strokeC.tim_s);
        strokeC.tim_len=(strokeC.tim_e>=strokeC.tim_s)?(strokeC.tim_e-strokeC.tim_s + compen):0;
        strokeC.tim_trg=1;
        single_trg+=1;
        strokeC.tim_len=(strokeC.tim_len & 0x00ffffff)|(0x04000000);
        SendMsg(&MsgSystem,MSG_COUNT,strokeC.tim_len,strokeC.tim_s);

        compen=-2;
    }

}

//////////////////////////////////////////rs485////////////////////////////////////////////////////////
uint16_t Rev16(uint16_t val)
{
    uint8_t a,b;
    uint16_t c;

    a=(val>>8)&0xff;
    b=val&0xff;
    c=(b<<8)|a;
    return c;
}

uint8_t crc_verify(uint8_t *p,uint16_t len)//stm8是大端模式
{
    uint16_t crc1=0,crc2=0;

    memcpy((uint8_t*)&crc1,p+len-2,2);
    crc1=Rev16(crc1);
    crc2=CRC_GetModbus16(p,len-2);
    if(crc1==crc2)
        return 1;
    else
        return 0;
}

//485实时数据包应答
uint16_t Pkt_485ackquery(uint8_t addrID,uint8_t funID,uint16_t saddr,uint16_t offset, Rs485u16Rlt *rlt, uint8_t *packet)
{
    uint16_t len=0;
    uint16_t crc16=0;
    uint16_t rlt16[8];

    if(rlt==NULL)
        return 0;
    if(packet==NULL)
        return 0;
    if(saddr > 7)
        return 0;
    if((offset==0)||(offset > 7))
        return 0;


    if((saddr + offset) > 7)//如果地址加偏移错误，自动修正
        offset= 7-saddr;

    memset(packet,0,128);
    memset((uint8_t*)&c_ackquery,0,128);
    c_ackquery.addrID=addrID;
    c_ackquery.funID=funID;

    rlt16[0]=rlt->index;
    rlt16[1]=rlt->phase;
    rlt16[2]=rlt->tlen;
    rlt16[3]=rlt->ym;
    rlt16[4]=rlt->dh;
    rlt16[5]=rlt->ms;
    rlt16[6]=rlt->batt;

    c_ackquery.length=offset*2;//偏移量从1开始计算

    memcpy(c_ackquery.buf,(uint8_t*)&rlt16[saddr],c_ackquery.length);
    len= 3 + c_ackquery.length;
    memcpy(packet,(uint8_t*)&c_ackquery,len);
    crc16=CRC_GetModbus16(packet,len);
    crc16=Rev16(crc16);
    memcpy((packet+len),(uint8_t*)&crc16,2);//拷贝CRC
    return (len+2);

}

void Get_Record(uint8_t tag)
{
    uint8_t result=0;

    if(tag==0)//如果超时从当前最新的记录开始读取，否则读取下一条记录
    {
        if(data_index.used)//有效数据
        {
            if(data_index.w>0)
                data_index.r=data_index.w-1;
            else
                data_index.r=89;
        }
        else
            data_index.r=0;
        result=Load_Data(2, (uint8_t *)&lrecd);
    }
    else
        result=Load_Data(0, (uint8_t *)&lrecd);

    if(result)
    {
        r485rlt.index=data_index.r+1;
        r485rlt.phase=(lrecd.pl >> 24)&0xff;
        r485rlt.tlen=(lrecd.pl & 0x0000ffff);
        r485rlt.ym=(lrecd.year<<8)|lrecd.mon;
        r485rlt.dh=(lrecd.day<<8)|lrecd.hour;
        r485rlt.ms=(lrecd.min<<8)|lrecd.sec;
        r485rlt.batt=(uint16_t)(Verfin/100);
    }
}


void Rs485_Proc(void)
{
    static uint8_t temp1=0,temp2=0,stateU=0,timeout=10;
    uint16_t pktlen=0,recbyte=0,len1=0;

    if(timeout)//2s超时计数
        timeout--;

    while(u1buf.r!=u1buf.w)
    {
        temp2=temp1;
        temp1=u1buf.recbuf[u1buf.r];
        u1buf.r=(u1buf.r+1)%UBUFLEN;

        switch(stateU)
        {
        case 1://下取数据,0x03
            rsUbuf[recbyte++] = temp1;
            if (recbyte >= RS485_AQ_PktLen)//一个包长 8bytes
            {
                memset((uint8_t*)&m_query,0,RS485_AQ_PktLen);
                memcpy((uint8_t*)&m_query,rsUbuf,RS485_AQ_PktLen);

                if(crc_verify((u8*)&m_query,RS485_AQ_PktLen))//主机数据校验ok
                {
                    Get_Record(timeout);
                    timeout=10;
                    len1=Pkt_485ackquery(r485id,0x03,m_query.staddr,m_query.offset,&r485rlt,pkt1);
                    if(len1>5)
                    {
                        Uart1_Send(pkt1,len1);
                    }
                }
                stateU=0;
            }
            break;

        case 0:
            if((r485id==temp2)&&(0x03==temp1))//下取数据
            {
                memset(rsUbuf,0,128);
                recbyte= 0;
                pktlen=0;
                rsUbuf[recbyte++] = temp2;
                rsUbuf[recbyte++] = temp1;
                stateU = 1;
            }
            break;

        default:
            stateU=0;
            break;
        }
    }
}//用于检测485接口是否接收到有效数据，100ms

void Chk_State(void)
{
    static uint8_t last=0;

    last=sysmode;
    sysmode=GPIO_ReadInputDataBit(GPIOC,GPIO_Pin_4);
    if(last != sysmode)
    {
        if(sysmode)//电池
        {
            USART_DeInit(USART1);		//复位UART1
            GPIO_Init(GPIOC, 0xEC, GPIO_Mode_Out_PP_Low_Slow);//除PC0，PC1(I2C1)，PC4
        }
        else//AC
        {
            Uart1_Init();
        }
        delay_halt=HALT_TIMEOUT;
    }
}

